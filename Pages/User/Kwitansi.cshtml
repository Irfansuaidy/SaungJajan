@page
@model SAUNGJAJAN.Pages.User.KwitansiModel
@{
    ViewData["Title"] = "Kwitansi";
}

<style>
    .receipt {
        max-width: 760px;
        margin: 30px auto;
        font-family: Arial, sans-serif;
        border: 1px solid #ddd;
        padding: 24px;
        border-radius: 12px;
    }

    .top {
        display: flex;
        justify-content: space-between;
        border-bottom: 1px solid #ddd;
        padding-bottom: 14px;
        margin-bottom: 18px;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 14px;
    }

    th, td {
        padding: 10px;
        border-bottom: 1px solid #ddd;
    }

    .right {
        text-align: right;
    }

    .center {
        text-align: center;
    }

    .btn {
        padding: 9px 14px;
        border-radius: 8px;
        border: none;
        text-decoration: none;
        cursor: pointer;
        display: inline-block;
    }

    .btn-primary {
        background: #2563eb;
        color: white;
    }

    .btn-secondary {
        background: #64748b;
        color: white;
    }

    .no-print {
        max-width: 760px;
        margin: 30px auto 0;
        display: flex;
        justify-content: space-between;
    }

    @@media print {
        .no-print {
            display: none !important;
        }

        .receipt {
            border: none;
            margin: 0;
            max-width: 100%;
        }
    }
</style>

@if (Model.Data == null)
{
    <div class="receipt">
        <strong>Kwitansi tidak ditemukan.</strong>
    </div>
}
else
{
    <div class="no-print">
        <a asp-page="/User/LogPesanan" class="btn btn-secondary">Kembali</a>
        <button onclick="window.print()" class="btn btn-primary">Cetak</button>
    </div>

    <div class="receipt">
        <div class="top">
            <div>
                <h2>Kwitansi</h2>
                <div>No: <strong>@Model.Data.KodeKwitansi</strong></div>
            </div>

            <div class="right">
                <div>Pesanan #@Model.Data.IdPesanan</div>
                <div>@Model.Data.WaktuDiteruskan.ToString("dd/MM/yyyy HH:mm")</div>
            </div>
        </div>

        <p>Pembeli: <strong>@Model.Data.NamaPembeli</strong></p>
        <p>Toko: <strong>@Model.Data.NamaToko</strong></p>
        <p>Status Pembayaran: <strong>@Model.Data.StatusPembayaran</strong></p>

        <table>
            <thead>
                <tr>
                    <th>Produk</th>
                    <th class="center">Qty</th>
                    <th class="right">Harga</th>
                    <th class="right">Subtotal</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model.Data.Items)
                {
                    <tr>
                        <td>@item.NamaProduk</td>
                        <td class="center">@item.Quantity</td>
                        <td class="right">Rp @item.Harga.ToString("N0")</td>
                        <td class="right">Rp @item.Subtotal.ToString("N0")</td>
                    </tr>
                }
            </tbody>

            <tfoot>
                <tr>
                    <th colspan="3" class="right">Total</th>
                    <th class="right">Rp @Model.Data.JumlahBayar.ToString("N0")</th>
                </tr>
            </tfoot>
        </table>

        <p style="margin-top:24px;font-size:13px;">
            Pembayaran dilakukan menggunakan saldo aplikasi.
        </p>
    </div>
}