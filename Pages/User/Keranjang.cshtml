@page
@model SAUNGJAJAN.Pages.User.KeranjangModel
@{
    ViewData["Title"] = "Keranjang";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1">Keranjang</h2>
            <p class="text-muted mb-0">
                Pembeli: <strong>@Model.UserNama</strong> |
                Saldo: <strong>Rp @Model.UserSaldo.ToString("N0")</strong>
            </p>
        </div>

        <div class="d-flex gap-2">
            <a asp-page="/User/Menu" class="btn btn-secondary">Kembali ke Menu</a>
            <a asp-page="/User/LogPesanan" class="btn btn-outline-primary">Log Pesanan</a>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
    {
        <div class="alert alert-success">@Model.SuccessMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }

    @if (!Model.KeranjangTokoList.Any())
    {
        <div class="alert alert-warning">
            Keranjang masih kosong.
        </div>
    }
    else
    {
        <form method="post" id="checkoutForm" asp-page-handler="CheckoutSelected"></form>

        foreach (var toko in Model.KeranjangTokoList)
        {
            <div class="card mb-4 shadow-sm">
                <div class="card-header bg-white">
                    <h4 class="mb-0">@toko.NamaToko</h4>
                </div>

                <div class="card-body">
                    <table class="table table-bordered align-middle">
                        <thead>
                            <tr>
                                <th class="text-center" style="width: 60px;">Pilih</th>
                                <th>Produk</th>
                                <th class="text-end">Harga</th>
                                <th class="text-center">Stok</th>
                                <th class="text-center">Qty</th>
                                <th class="text-end">Subtotal</th>
                                <th class="text-center">Aksi</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var item in toko.Detail)
                            {
                                <tr>
                                    <td class="text-center">
                                        <input type="checkbox"
                                               form="checkoutForm"
                                               name="selectedKeranjangIds"
                                               value="@item.IdKeranjang"
                                               class="form-check-input item-check" />
                                    </td>

                                    <td>@item.NamaProduk</td>

                                    <td class="text-end">
                                        Rp @item.Harga.ToString("N0")
                                    </td>

                                    <td class="text-center">
                                        @item.Stok
                                    </td>

                                    <td class="text-center" style="width: 140px;">
                                        <input type="number"
                                               form="checkoutForm"
                                               name="quantityUpdates[@item.IdKeranjang]"
                                               value="@item.Quantity"
                                               min="1"
                                               max="@item.Stok"
                                               class="form-control form-control-sm text-center" />
                                    </td>

                                    <td class="text-end">
                                        Rp @item.Subtotal.ToString("N0")
                                    </td>

                                    <td class="text-center">
                                        <form method="post" asp-page-handler="Remove"
                                              onsubmit="return confirm('Hapus produk ini dari keranjang?');">
                                            <input type="hidden" name="idKeranjang" value="@item.IdKeranjang" />
                                            <button type="submit" class="btn btn-sm btn-danger">
                                                Hapus
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>

                        <tfoot>
                            <tr>
                                <th colspan="5" class="text-end">Total Toko</th>
                                <th class="text-end">Rp @toko.TotalHarga.ToString("N0")</th>
                                <th></th>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        }

        <div class="card shadow-sm">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <strong>Checkout item yang dicentang.</strong>
                    <div class="text-muted small">
                        Jika item berasal dari beberapa toko, sistem akan membuat pesanan terpisah untuk tiap toko.
                    </div>
                </div>

                <button type="submit"
                        form="checkoutForm"
                        class="btn btn-success"
                        onclick="return confirm('Yakin ingin memesan semua produk yang dicentang? Saldo akan langsung dipotong.');">
                    Pesan Sekarang
                </button>
            </div>
        </div>
    }
</div>