@page
@model SAUNGJAJAN.Pages.User_Toko.DashboardModel
@{
    ViewData["Title"] = "Dashboard Toko";
}

<script src="https://cdn.tailwindcss.com"></script>

<div class="min-h-screen bg-slate-100">
    <div class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">

        <div class="mb-6 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <div>
                <h1 class="text-2xl font-bold text-slate-900">Dashboard Toko</h1>
                <p class="text-sm text-slate-500">
                    Kelola produk, stok, harga, dan pantau pesanan masuk.
                </p>
            </div>

            <div class="rounded-2xl bg-white px-5 py-3 shadow-sm ring-1 ring-slate-200">
                <p class="text-xs text-slate-500">Nama Toko</p>
                <p class="font-semibold text-slate-900">
                    @(Model.Toko?.NamaToko ?? "Toko tidak ditemukan")
                </p>
            </div>
            <a asp-page="/User_Toko/LaporanPenjualan" class="btn btn-primary"> 
                Laporan Penjualan
            </a>
            <a asp-page="/Auth/LogoutToko" class="rounded-xl bg-red-600 px-4 py-2 text-sm font-semibold text-white hover:bg-red-700">
                Logout
            </a>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
        {
            <div class="mb-4 rounded-xl bg-emerald-50 px-4 py-3 text-sm font-medium text-emerald-700 ring-1 ring-emerald-200">
                @Model.SuccessMessage
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <div class="mb-4 rounded-xl bg-red-50 px-4 py-3 text-sm font-medium text-red-700 ring-1 ring-red-200">
                @Model.ErrorMessage
            </div>
        }

        <div class="mb-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
            <div class="rounded-2xl bg-white p-5 shadow-sm ring-1 ring-slate-200">
                <p class="text-sm text-slate-500">Total Produk</p>
                <p class="mt-2 text-3xl font-bold text-slate-900">@Model.TotalProduk</p>
            </div>

            <div class="rounded-2xl bg-white p-5 shadow-sm ring-1 ring-slate-200">
                <p class="text-sm text-slate-500">Total Stok</p>
                <p class="mt-2 text-3xl font-bold text-slate-900">@Model.TotalStok</p>
            </div>

            <div class="rounded-2xl bg-white p-5 shadow-sm ring-1 ring-slate-200">
                <p class="text-sm text-slate-500">Pesanan Masuk</p>
                <p class="mt-2 text-3xl font-bold text-slate-900">@Model.TotalPesanan</p>
            </div>

            <div class="rounded-2xl bg-white p-5 shadow-sm ring-1 ring-slate-200">
                <p class="text-sm text-slate-500">Penjualan Lunas</p>
                <p class="mt-2 text-2xl font-bold text-slate-900">
                    Rp @Model.TotalPenjualanToko.ToString("N0")
                </p>
            </div>
        </div>

    <div class="flex items-center justify-between border-b border-slate-200 p-5">
        <div>
            <h2 class="text-lg font-bold text-slate-900">Daftar Produk</h2>
            <p class="text-sm text-slate-500">Ubah nama produk, jenis, harga, dan stok.</p>
        </div>
        <button type="button" onclick="document.getElementById('modalTambahProduk').classList.remove('hidden')"
                class="flex items-center gap-2 rounded-xl bg-blue-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-blue-700">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
            </svg>
            Tambah Produk
        </button>
    </div>

    <div class="overflow-x-auto">
        <table class="min-w-full text-left text-sm">
            <thead class="bg-slate-50 text-xs uppercase tracking-wide text-slate-500">
                <tr>
                    <th class="px-5 py-3">ID</th>
                    <th class="px-5 py-3">Nama Makanan</th>
                    <th class="px-5 py-3">Jenis</th>
                    <th class="px-5 py-3">Harga</th>
                    <th class="px-5 py-3">Stok</th>
                    <th class="px-5 py-3 text-right">Aksi</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                @if (Model.ProdukList.Any())
                {
                    foreach (var produk in Model.ProdukList)
                    {
                        <tr class="hover:bg-slate-50">
                            <form method="post" asp-page-handler="UpdateProduk" class="contents">
                                <input type="hidden" name="idProduk" value="@produk.IdProduk" />

                                <td class="px-5 py-3 font-medium text-slate-500">@produk.IdProduk</td>

                                <td class="px-5 py-3">
                                    <input name="namaMakanan" value="@produk.NamaMakanan"
                                           class="w-52 rounded-lg border border-slate-300 px-3 py-2 text-sm outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-100" />
                                </td>

                                <td class="px-5 py-3">
                                    <select name="jenis"
                                            class="rounded-lg border border-slate-300 px-3 py-2 text-sm outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-100">
                                            <option value="makanan" selected="@(produk.Jenis == "makanan")">Makanan</option>
                                            <option value="minuman" selected="@(produk.Jenis == "minuman")">Minuman</option>
                                    </select>
                                </td>

                                <td class="px-5 py-3">
                                    <input name="harga" type="number" min="0" step="500" value="@produk.Harga"
                                           class="w-28 rounded-lg border border-slate-300 px-3 py-2 text-sm outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-100" />
                                </td>

                                <td class="px-5 py-3">
                                    <input name="stok" type="number" min="0" value="@produk.Stok"
                                           class="w-20 rounded-lg border border-slate-300 px-3 py-2 text-sm outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-100" />
                                </td>

                                <td class="px-5 py-3 text-right">
                                    <div class="flex items-center justify-end gap-2">
                                        <button type="submit"
                                                class="rounded-lg bg-emerald-600 px-3 py-2 text-xs font-semibold text-white hover:bg-emerald-700">
                                            Simpan
                                        </button>
                                    </div>
                                </td>
                            </form>

                            <td class="px-5 py-3">
                                <form method="post" asp-page-handler="HapusProduk"
                                      onsubmit="return confirm('Yakin ingin menghapus produk ini?');">
                                    <input type="hidden" name="idProduk" value="@produk.IdProduk" />
                                    <button type="submit"
                                            class="rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-xs font-semibold text-red-600 hover:bg-red-100">
                                        Hapus
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="px-5 py-10 text-center text-slate-400">
                            Belum ada produk. Klik <strong>+ Tambah Produk</strong> untuk mulai.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div id="modalTambahProduk"
     class="fixed inset-0 z-50 hidden flex items-center justify-center bg-black/40 px-4"
     onclick="if(event.target===this) this.classList.add('hidden')">

    <div class="w-full max-w-md rounded-2xl bg-white shadow-xl ring-1 ring-slate-200">
        <div class="flex items-center justify-between border-b border-slate-200 px-6 py-4">
            <h3 class="font-bold text-slate-900">Tambah Produk Baru</h3>
            <button type="button" onclick="document.getElementById('modalTambahProduk').classList.add('hidden')"
                    class="text-slate-400 hover:text-slate-600">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </button>
        </div>

        <form method="post" asp-page-handler="TambahProduk" class="p-6">
            <div class="mb-4">
                <label class="mb-1 block text-sm font-medium text-slate-700">Nama Makanan</label>
                <input asp-for="ProdukInput.NamaMakanan"
                       class="w-full rounded-xl border border-slate-300 px-3 py-2.5 text-sm outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-100"
                       placeholder="Contoh: Mie Ayam" />
            </div>

            <div class="mb-4 grid grid-cols-3 gap-3">
                <div>
                    <label class="mb-1 block text-sm font-medium text-slate-700">Jenis</label>
                    <select asp-for="ProdukInput.Jenis"
                            class="w-full rounded-xl border border-slate-300 px-3 py-2.5 text-sm outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-100">
                        <option value="makanan">Makanan</option>
                        <option value="minuman">Minuman</option>
                    </select>
                </div>
                <div>
                    <label class="mb-1 block text-sm font-medium text-slate-700">Harga (Rp)</label>
                    <input asp-for="ProdukInput.Harga" type="number" min="0" step="500"
                           class="w-full rounded-xl border border-slate-300 px-3 py-2.5 text-sm outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-100"
                           placeholder="7000" />
                </div>
                <div>
                    <label class="mb-1 block text-sm font-medium text-slate-700">Stok</label>
                    <input asp-for="ProdukInput.Stok" type="number" min="0"
                           class="w-full rounded-xl border border-slate-300 px-3 py-2.5 text-sm outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-100"
                           placeholder="50" />
                </div>
            </div>

            <div class="flex justify-end gap-2 border-t border-slate-100 pt-4">
                <button type="button" onclick="document.getElementById('modalTambahProduk').classList.add('hidden')"
                        class="rounded-xl border border-slate-300 px-4 py-2 text-sm font-medium text-slate-600 hover:bg-slate-50">
                    Batal
                </button>
                <button type="submit"
                        class="rounded-xl bg-blue-600 px-5 py-2 text-sm font-semibold text-white hover:bg-blue-700">
                    Tambah Produk
                </button>
            </div>
        </form>
    </div>
</div>

        <div class="rounded-2xl bg-white shadow-sm ring-1 ring-slate-200">
            <div class="border-b border-slate-200 p-5">
                <h2 class="text-lg font-bold text-slate-900">Log Pesanan User</h2>
                <p class="text-sm text-slate-500">
                    Riwayat pesanan yang berisi produk dari toko ini.
                </p>
            </div>

            <div class="overflow-x-auto">
                <table class="min-w-full text-left text-sm">
                    <thead class="bg-slate-50 text-xs uppercase tracking-wide text-slate-500">
                        <tr>
                            <th class="px-5 py-3">ID Pesanan</th>
                            <th class="px-5 py-3">ID User</th>
                            <th class="px-5 py-3">Waktu Pesan</th>
                            <th class="px-5 py-3">Total Item</th>
                            <th class="px-5 py-3">Total Toko</th>
                            <th class="px-5 py-3">Status</th>
                            <th class="px-5 py-3">Detail</th>
                        </tr>
                    </thead>

                    <tbody class="divide-y divide-slate-100">
                        @if (Model.PesananList.Any())
                        {
                            foreach (var pesanan in Model.PesananList)
                            {
                                <tr class="align-top hover:bg-slate-50">
                                    <td class="px-5 py-4 font-semibold text-slate-800">
                                        #@pesanan.IdPesanan
                                    </td>

                                    <td class="px-5 py-4 text-slate-700">
                                        @pesanan.IdUser
                                    </td>

                                    <td class="px-5 py-4 text-slate-700">
                                        @pesanan.WaktuPesan.ToString("dd MMM yyyy HH:mm")
                                    </td>

                                    <td class="px-5 py-4 text-slate-700">
                                        @pesanan.TotalItem
                                    </td>

                                    <td class="px-5 py-4 font-semibold text-slate-900">
                                        Rp @pesanan.TotalHargaToko.ToString("N0")
                                    </td>

                                    <td class="px-5 py-4">
                                        <form method="post" asp-page-handler="UpdateStatus" class="flex items-center gap-2">
                                            <input type="hidden" name="idPesanan" value="@pesanan.IdPesanan" />

                                            <select name="status"
                                                    class="rounded-lg border border-slate-300 px-3 py-2 text-sm outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-100">
                                                @foreach (var status in new[] { "Diproses", "Siap", "Lunas" })
                                                {
                                                    if (pesanan.Status == status)
                                                    {
                                                        <option value="@status" selected>@status</option>
                                                    }
                                                    else
                                                    {
                                                        <option value="@status">@status</option>
                                                    }
                                                }
                                            </select>

                                            <button type="submit"
                                                    class="rounded-lg bg-slate-900 px-3 py-2 text-xs font-semibold text-white hover:bg-slate-700">
                                                Update
                                            </button>
                                        </form>
                                    </td>

                                    <td class="px-5 py-4">
                                        <details class="group">
                                            <summary class="cursor-pointer rounded-lg bg-blue-50 px-3 py-2 text-xs font-semibold text-blue-700 hover:bg-blue-100">
                                                Lihat Detail
                                            </summary>

                                            <div class="mt-3 overflow-hidden rounded-xl border border-slate-200">
                                                <table class="min-w-80 text-sm">
                                                    <thead class="bg-slate-50 text-xs text-slate-500">
                                                        <tr>
                                                            <th class="px-3 py-2 text-left">Produk</th>
                                                            <th class="px-3 py-2 text-left">Qty</th>
                                                            <th class="px-3 py-2 text-left">Subtotal</th>
                                                        </tr>
                                                    </thead>

                                                    <tbody class="divide-y divide-slate-100">
                                                        @foreach (var detail in pesanan.Detail)
                                                        {
                                                            <tr>
                                                                <td class="px-3 py-2">
                                                                    @detail.NamaProduk
                                                                    <span class="text-xs text-slate-400">
                                                                        (#@detail.IdProduk)
                                                                    </span>
                                                                </td>

                                                                <td class="px-3 py-2">
                                                                    @detail.Quantity
                                                                </td>

                                                                <td class="px-3 py-2 font-medium">
                                                                    Rp @detail.Subtotal.ToString("N0")
                                                                </td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </table>
                                            </div>
                                        </details>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="px-5 py-8 text-center text-slate-500">
                                    Belum ada pesanan untuk toko ini.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

    </div>
</div>