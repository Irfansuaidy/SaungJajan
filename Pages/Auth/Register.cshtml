@page
@model SAUNGJAJAN.Pages.Auth.RegisterModel
@{
    ViewData["Title"] = "Daftar Akun";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow rounded-4 border-0">
                <div class="card-body p-4">
                    <h2 class="text-center mb-2">Saung Jajan</h2>
                    <p class="text-center text-muted mb-4">Buat akun baru</p>

                    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                    {
                        <div class="alert alert-danger">
                            @Model.ErrorMessage
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
                    {
                        <div class="alert alert-success">
                            @Model.SuccessMessage
                        </div>
                    }

                    <form method="post">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label class="form-label">Nama Lengkap</label>
                            <input type="text"
                                   name="Input.Nama"
                                   class="form-control rounded-3"
                                   placeholder="Contoh: Budi Santoso"
                                   value="@Model.Input.Nama"
                                   required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Email</label>
                            <input type="email"
                                   name="Input.Email"
                                   class="form-control rounded-3"
                                   placeholder="contoh@email.com"
                                   value="@Model.Input.Email"
                                   required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Password</label>
                            <input type="password"
                                   name="Input.Password"
                                   class="form-control rounded-3"
                                   placeholder="Minimal 6 karakter"
                                   required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Konfirmasi Password</label>
                            <input type="password"
                                   name="Input.KonfirmasiPassword"
                                   class="form-control rounded-3"
                                   placeholder="Ulangi password"
                                   required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Saldo Awal (Rp)</label>
                            <input type="number"
                                   name="Input.Saldo"
                                   class="form-control rounded-3"
                                   placeholder="0"
                                   value="@Model.Input.Saldo"
                                   min="0"
                                   step="1000" />
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary rounded-3">
                                Register
                            </button>
                        </div>
                    </form>

                    <div class="text-center mt-3">
                        Sudah punya akun?
                        <a asp-page="/Auth/Login">Login</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}