@page
@model SAUNGJAJAN.Pages.Auth.LoginTokoModel
@{
    ViewData["Title"] = "Login Toko";
}

<div class="container py-5" style="max-width: 500px;">
    <div class="card shadow-sm border-0">
        <div class="card-body p-4">
            <h3 class="mb-2">Login Toko</h3>
            <p class="text-muted mb-4">Pilih toko untuk masuk ke dashboard toko.</p>

            @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
            {
                <div class="alert alert-danger">
                    @Model.ErrorMessage
                </div>
            }

            <form method="post">
                <div class="mb-3">
                    <label class="form-label">Pilih Toko</label>
                    <select asp-for="IdToko" asp-items="Model.TokoOptions" class="form-select" required>
                        <option value="">-- Pilih toko --</option>
                    </select>
                </div>

                <button type="submit" class="btn btn-primary w-100">
                    Masuk Dashboard Toko
                </button>
            </form>

            <div class="mt-3 text-center">
                <a asp-page="/Auth/Login">Login sebagai User</a>
            </div>
        </div>
    </div>
</div>